<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F8F9FA">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="MySQL Clone Engine"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/sqlInput"
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:background="#FFFFFF"
        android:gravity="top|start"
        android:hint="Type your SQL command here...\nExample: CREATE TABLE users (id INTEGER, name TEXT);"
        android:inputType="textMultiLine|textNoSuggestions"
        android:padding="12dp"
        android:textColor="#000000"
        android:textSize="16sp" />

    <Button
        android:id="@+id/runButton"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="12dp"
        android:text="Execute Query"
        android:textSize="18sp"
        android:backgroundTint="#007BFF"
        android:textColor="#FFFFFF"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="16dp">

        <TextView
            android:id="@+id/outputText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Console Output Ready..."
            android:textColor="#555555"
            android:textSize="16sp"
            android:padding="8dp"
            android:background="#E9ECEF"/>
    </ScrollView>

</LinearLayout>
